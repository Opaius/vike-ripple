{
  "name": "@ripple-ts/vite-plugin",
  "description": "Vite plugin for Ripple",
  "license": "MIT",
  "author": "Dominic Gannaway",
  "version": "0.3.84",
  "type": "module",
  "module": "src/index.js",
  "main": "src/index.js",
  "bin": {
    "ripple-preview": "src/bin/preview.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./production": {
      "import": "./src/server/production.js",
      "default": "./src/server/production.js",
      "types": "./types/production.d.ts"
    }
  },
  "homepage": "https://ripple-ts.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ripple-TS/ripple.git",
    "directory": "packages/vite-plugin"
  },
  "bugs": {
    "url": "https://github.com/Ripple-TS/ripple/issues"
  },
  "dependencies": {
    "@ripple-ts/adapter": "0.3.84",
    "@tsrx/ripple": "0.1.32"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "type-fest": "^5.6.0",
    "vite": "^8.0.12",
    "ripple": "0.3.84"
  },
  "publishConfig": {
    "access": "public"
  }
}
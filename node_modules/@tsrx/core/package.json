    "./test-harness/runtime/*.tsrx": "./tests/shared/runtime/*.tsrx"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@noble/hashes": "^2.2.0",
    "@sveltejs/acorn-typescript": "^1.0.10",
    "@types/estree-jsx": "^1.0.5",
    "@types/estree": "^1.0.8",
    "acorn": "^8.16.0",
    "esrap": "^2.2.8",

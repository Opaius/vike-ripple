{
	"name": "@cioky/ripple-query-remult",
	"version": "0.2.1",
	"description": "Remult adapter for @cioky/ripple-query — useQuery, mutation, typed invalidation registry, LiveQuery, Infinite Query",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./use-query": {
			"types": "./use-query.ts",
			"default": "./use-query.ts"
		},
		"./use-live-query": {
			"types": "./use-live-query.ts",
			"default": "./use-live-query.ts"
		},
		"./use-infinite-query": {
			"types": "./use-infinite-query.ts",
			"default": "./use-infinite-query.ts"
		}
	},
	"files": [
		"src",
		"use-query.tsrx",
		"use-query.ts",
		"use-live-query.tsrx",
		"use-live-query.ts",
		"use-infinite-query.tsrx",
		"use-infinite-query.ts"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Opaius/vike-ripple.git"
	},
	"homepage": "https://github.com/Opaius/vike-ripple",
	"bugs": {
		"url": "https://github.com/Opaius/vike-ripple/issues"
	},
	"keywords": [
		"ripple",
		"remult",
		"query",
		"livequery"
	],
	"license": "MIT",
	"peerDependencies": {
		"@cioky/ripple-query": "0.2.x",
		"remult": ">=0.26.0",
		"remult-partykit": ">=0.0.1"
	}
}

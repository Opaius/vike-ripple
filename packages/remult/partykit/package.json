{
  "name": "remult-partykit",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Opaius/vike-ripple.git",
    "directory": "packages/remult-partykit"
  },
  "homepage": "https://github.com/Opaius/vike-ripple/tree/main/packages/remult-partykit#readme",
  "bugs": {
    "url": "https://github.com/Opaius/vike-ripple/issues"
  },
  "description": "Real-time sync for Remult using Cloudflare Durable Objects and PartyServer",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./durable-object": {
      "types": "./dist/durable-object.d.ts",
      "import": "./dist/durable-object.js",
      "default": "./dist/durable-object.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "peerDependencies": {
    "partyserver": "^0.5.0",
    "remult": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "partyserver": "^0.5.6",
    "remult": "^3.3.13",
    "typescript": "^6.0.3"
  }
}
